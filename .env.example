# Surfshark WireGuard credentials (optional VPN layer).
# Copy to .env and fill in if you want VPN. Leave empty/commented to run without VPN.
# .env is gitignored — never commit real keys.

# Surfshark dashboard: VPN > Manual Setup > WireGuard > "I don't have a keypair" > Generate
# The Private Key is shown ONLY ONCE — copy immediately.
SURFSHARK_PRIVATE_KEY=

# From the .conf file Surfshark generates: the "Address = ..." IPv4 line (with /16).
# This is the same value for every Surfshark server.
SURFSHARK_ADDRESS=10.14.0.2/16

# Optional: which country to start with (ISO-2 code or full name).
# Examples: DE | NL | "Germany" | "Netherlands"
SURFSHARK_COUNTRY=DE

# Optional: local SOCKS5 port wireproxy listens on. Default 1080.
SURFSHARK_SOCKS_PORT=1080
